kind: pipeline
type: docker
name: pr-review

steps:
  - name: ai-pr-review
    image: your-registry/drone-ai-review:latest
    environment:
      PLUGIN_MODE: pr
      PLUGIN_PROVIDER: codex
      PLUGIN_OUTPUT: artifacts/review.json

---
kind: pipeline
type: docker
name: full-review

trigger:
  branch:
    - main
  event:
    - push

steps:
  - name: ai-full-review
    image: your-registry/drone-ai-review:latest
    environment:
      PLUGIN_MODE: full
      PLUGIN_PROVIDER: claude
      PLUGIN_OUTPUT: artifacts/review.md
